<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textAppearance="?attr/textAppearanceHeadline6"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true" />

        <ImageButton
            android:id="@+id/button_exit_settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/arrow_menu_close_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/settings_content_desc_exit_button"
            app:tint="?attr/colorControlNormal"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"/>
    </RelativeLayout>

    <!-- Airspaces Toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_airspaces"
            android:textAppearance="?attr/textAppearanceSubtitle1"/>
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_airspaces"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"/>
    </LinearLayout>

    <!-- Hotspots Toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_hotspots"
            android:textAppearance="?attr/textAppearanceSubtitle1"/>
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_hotspots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- PG Launches Toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_pglaunches"
            android:textAppearance="?attr/textAppearanceSubtitle1"/>
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_pglaunches"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?android:attr/listDivider"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"/>

    <!-- Map View Toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_map_view"
            android:textAppearance="?attr/textAppearanceSubtitle1"/>
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_group_map_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            android:checkedButton="@+id/button_map_view_terrain">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_map_view_terrain"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:minWidth="0dp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_height="wrap_content"
                android:text="@string/settings_map_view_terrain"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_map_view_satellite"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:minWidth="0dp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_height="wrap_content"
                android:text="@string/settings_map_view_satellite"/>
        </com.google.android.material.button.MaterialButtonToggleGroup>
    </LinearLayout>

    <!-- Temperature Units -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_units_temperature"
            android:textAppearance="?attr/textAppearanceSubtitle1"/>
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_group_temp_units"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            android:checkedButton="@+id/button_temp_celsius">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_temp_celsius"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:minWidth="0dp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_height="wrap_content"
                android:text="@string/settings_units_temp_celsius"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_temp_fahrenheit"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:minWidth="0dp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_height="wrap_content"
                android:text="@string/settings_units_temp_fahrenheit"/>
        </com.google.android.material.button.MaterialButtonToggleGroup>
    </LinearLayout>

    <!-- Distance Units -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_units_distance"
            android:textAppearance="?attr/textAppearanceSubtitle1"/>
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_group_dist_units"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            android:checkedButton="@+id/button_dist_km">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_dist_km"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:minWidth="0dp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_height="wrap_content"
                android:text="@string/settings_units_dist_km"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_dist_miles"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:minWidth="0dp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_height="wrap_content"
                android:text="@string/settings_units_dist_miles"/>
        </com.google.android.material.button.MaterialButtonToggleGroup>
    </LinearLayout>

    <!-- Speed Units -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_units_speed"
            android:textAppearance="?attr/textAppearanceSubtitle1"/>
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_group_speed_units"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            android:checkedButton="@+id/button_speed_kmh">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_speed_kmh"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:minWidth="0dp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_height="wrap_content"
                android:text="@string/settings_units_speed_kmh"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_speed_mph"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:minWidth="0dp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_height="wrap_content"
                android:text="@string/settings_units_speed_mph"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_speed_ms"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:minWidth="0dp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_height="wrap_content"
                android:text="@string/settings_units_speed_ms"/>
        </com.google.android.material.button.MaterialButtonToggleGroup>
    </LinearLayout>

    <!-- Altitude Units -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="0dp"> <!-- Last item, so 0dp margin -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_units_altitude"
            android:textAppearance="?attr/textAppearanceSubtitle1"/>
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_group_alt_units"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            android:checkedButton="@+id/button_alt_meters">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_alt_meters"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:minWidth="0dp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_height="wrap_content"
                android:text="@string/settings_units_alt_meters"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_alt_feet"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:minWidth="0dp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_height="wrap_content"
                android:text="@string/settings_units_alt_feet"/>
        </com.google.android.material.button.MaterialButtonToggleGroup>
    </LinearLayout>

</LinearLayout>