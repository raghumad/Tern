<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Tern" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/cyan_500</item>
        <item name="colorPrimaryVariant">@color/cyan_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/light_cyan_accent</item>
        <item name="colorSecondaryVariant">@color/cyan_700</item> <!-- Or @color/cyan_500 -->
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Custom font -->
        <item name="android:fontFamily">@font/gruppo_regular</item>
        <!-- Customize your theme here. -->
    </style>

    <!-- Theme for MainActivity without an ActionBar -->
    <style name="Theme.Tern.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Re-apply necessary attributes from Theme.Tern -->
        <item name="colorPrimary">@color/cyan_500</item>
        <item name="colorPrimaryVariant">@color/cyan_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/light_cyan_accent</item>
        <item name="colorSecondaryVariant">@color/cyan_700</item> <!-- Or @color/cyan_500 -->
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="android:fontFamily">@font/gruppo_regular</item>
    </style>
</resources>