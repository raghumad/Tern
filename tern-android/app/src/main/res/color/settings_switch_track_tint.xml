<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- State when switch is checked -->
    <item android:color="@color/cyan_500" android:state_checked="true" />
    <!-- Default state (unchecked) -->
    <!-- Using colorControlNormal for a standard neutral, you can adjust alpha or use a specific gray -->
    <item android:color="?android:attr/colorForeground" android:alpha="0.38" />
</selector>