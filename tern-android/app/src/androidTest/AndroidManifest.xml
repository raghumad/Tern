<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!--
      The test APK's merged manifest pulls in androidx.startup's
      InitializationProvider (via androidTest deps), but the startup-runtime
      classes live only in the app-under-test APK, so the test process crashes on
      launch with ClassNotFoundException. Remove the provider from the *test* APK;
      the app APK keeps its own and initializes normally in its own process.
    -->
    <application>
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            tools:node="remove" />
    </application>
</manifest>
